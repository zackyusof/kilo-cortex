# ============================================================
# KILO CORTEX — Environment Configuration
# ============================================================
# Copy this file to .env and customize values.
# All defaults work out of the box — this is for overrides.
# ============================================================

# ─── MariaDB ─────────────────────────────────────────────────
MARIADB_PORT=3306
MARIADB_ROOT_PASSWORD=kilo_root_change_me
MARIADB_DATABASE=kilo
MARIADB_USER=kilo
MARIADB_PASSWORD=kilo_pass_change_me

# ─── Redis ───────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=kilo_redis_change_me

# ─── Qdrant ──────────────────────────────────────────────────
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=kilo_qdrant_change_me

# ─── Ollama ──────────────────────────────────────────────────
OLLAMA_PORT=11434
OLLAMA_GPU=false
EMBEDDING_MODEL=all-minilm
DEFAULT_DIMS=384

# ─── Obsidian ────────────────────────────────────────────────
OBSIDIAN_WEB_PORT=3000
OBSIDIAN_VNC_PORT=5900

# ─── Memory API ──────────────────────────────────────────────
MEMORY_API_PORT=8088
